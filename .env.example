# ==============================================================================
# 数据库与中间件基础配置 (请全部替换为强密码)
# ==============================================================================

# MySQL 数据库 Root 用户的登录密码
MYSQL_ROOT_PASSWORD=your_mysql_password

# RabbitMQ 消息队列的默认账号和密码
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=your_rabbitmq_password

# MinIO 对象存储服务的超级管理员账号和密码 (用于后台登录和 API 鉴权)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_minio_password
# 博客系统在 MinIO 中使用的存储桶名称
MINIO_BUCKETNAME=blog

# ==============================================================================
# Spring Boot 核心安全与环境配置
# ==============================================================================

# 运行环境配置：指定当前为生产环境 (会读取 application-prod.yml)
SPRING_PROFILES_ACTIVE=prod

# 数据库连接 URL：使用 docker-compose 中的服务名 'mysql' 进行内网连接
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/blog?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai

# Redis 配置：指定使用的数据库编号 (0-15，这里用 1 避免与默认的 0 冲突)
SPRING_DATA_REDIS_DATABASE=1

# JWT 安全令牌配置
# 签发 JWT 用的加密秘钥 (必须是非常复杂且保密的字符串)
SPRING_SECURITY_JWT_KEY=your-jwt-secret-key
# JWT 令牌的有效天数
SPRING_SECURITY_JWT_EXPIRE=7

# ==============================================================================
# RabbitMQ 消息队列路由配置 (无需修改，保持默认即可)
# ==============================================================================
SPRING_RABBITMQ_QUEUE_EMAIL=email_queue
SPRING_RABBITMQ_QUEUE_LOG_LOGIN=log_login_queue
SPRING_RABBITMQ_QUEUE_LOG_SYSTEM=log_system_queue
SPRING_RABBITMQ_EXCHANGE_EMAIL=email_exchange
SPRING_RABBITMQ_EXCHANGE_LOG=log_exchange
SPRING_RABBITMQ_ROUTINGKEY_EMAIL=email_routing_key
SPRING_RABBITMQ_ROUTINGKEY_LOG_LOGIN=log_routing_key_login
SPRING_RABBITMQ_ROUTINGKEY_LOG_SYSTEM=log_routing_key_system

# ==============================================================================
# 邮件发送服务配置 (以 QQ 邮箱为例)
# ==============================================================================

# SMTP 服务器地址 (QQ 邮箱固定为 smtp.qq.com)
SPRING_MAIL_HOST=smtp.qq.com
# SMTP 端口号 (加密传输端口)
SPRING_MAIL_PORT=587
# 用来发邮件的真实邮箱地址
SPRING_MAIL_USERNAME=your_email@qq.com
# 邮箱的 SMTP 授权码 (注意：绝对不是邮箱登录密码)
SPRING_MAIL_PASSWORD=your_smtp_auth_code

# 开启邮件发送的安全认证和 TLS 加密
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# ==============================================================================
# 业务功能开关与前端路由地址
# ==============================================================================

# 邮件通知开关：是否在以下场景发送提醒邮件 (true/false)
MAIL_ARTICLE_EMAIL_NOTICE=false  # 文章被评论时
MAIL_ARTICLE_REPLY_NOTICE=false  # 文章评论被回复时
MAIL_MESSAGE_EMAIL_NOTICE=false  # 留言板有新留言时
MAIL_MESSAGE_REPLY_NOTICE=false  # 留言被回复时
MAIL_MESSAGE_NEW_NOTICE=false    # (备用留言通知开关)
MAIL_APPLY_NOTICE=false          # 有新的友链申请时
MAIL_PASS_NOTICE=false           # 友链审核通过时

# 面向外部用户的真实访问地址 (务必填写真实域名，不要用 localhost)
# 用户点击邮件里的“确认申请/激活”等链接时，跳转到的后端接口完整地址
MAIL_LINK_APPLY_REDIRECT_URI=http://admin.example.com/api/link/email/apply
# 博客前台首页的完整地址
WEB_INDEX_PATH=http://www.example.com/