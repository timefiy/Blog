# production
NODE_ENV=production
VITE_APP_BASE_API=/api
# 使用反代不需要填写这个值
VITE_SERVE=
# 前端部署地址
VITE_FRONTEND_URL=http://www.zhuyuxi.xyz
# 音乐接口前缀
VITE_MUSIC_BASE_API=/wapi
# 音乐服务地址
VITE_MUSIC_SERVE=
# 音乐前端地址
VITE_MUSIC_FRONTEND_URL=
# 一言接口地址
VITE_YIYAN_API=https://v1.hitokoto.cn/?c=a&encode=json
# 是否启用 DevToolsBlocker 插件,阻止使用12查看网页元素
VITE_ENABLE_DEV_TOOLSBLOCKER=true
